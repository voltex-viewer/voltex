{
  "name": "voltex",
  "version": "1.0.0",
  "description": "View and analyse MDF/MF4, CSV and other measurement data in your browser.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:web": "vite build --config vite.web.config.ts",
    "dev:web": "vite dev --config vite.web.config.ts --host 0.0.0.0",
    "preview:web": "vite preview --config vite.web.config.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/wicg-file-system-access": "^2023.10.6",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitest/ui": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "jszip": "^3.10.1",
    "puppeteer": "^24.39.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.1.6",
    "vite-plugin-eslint2": "^5.0.4",
    "vitest": "^4.0.1"
  },
  "keywords": [],
  "author": {
    "name": "Tom Gillbe"
  },
  "license": "MIT",
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@voltex-viewer/mdf-reader": "workspace:*",
    "@voltex-viewer/plugin-api": "workspace:*",
    "fp-ts": "^2.16.11",
    "io-ts": "^2.2.22"
  }
}
